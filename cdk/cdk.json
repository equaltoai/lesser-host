{
  "app": "node dist/bin/lesser-host.js",
  "context": {
    "@aws-cdk/core:newStyleStackSynthesis": true,

    "webRootDomain": "lesser.host",
    "webHostedZoneId": "<YOUR_HOSTED_ZONE_ID>",
    "webHostedZoneName": "lesser.host",

    "bootstrapWalletAddress": "<YOUR_BOOTSTRAP_WALLET_ADDRESS>",

    "tipEnabledLab": "true",
    "tipChainIdLab": "11155111",
    "tipContractAddressLab": "<YOUR_TIP_CONTRACT_ADDRESS_LAB>",
    "tipRpcUrlSsmParamLab": "/lesser-host/api/infura/sepolia",

    "tipEnabledLive": "false",
    "tipChainIdLive": "1",
    "tipContractAddressLive": "",
    "tipRpcUrlSsmParamLive": "/lesser-host/api/infura/mainnet",

    "soulEnabledLab": "true",
    "soulChainIdLab": "11155111",
    "soulRegistryContractAddressLab": "<YOUR_SOUL_REGISTRY_CONTRACT_ADDRESS_LAB>",
    "soulReputationAttestationContractAddressLab": "<YOUR_SOUL_REPUTATION_ATTESTATION_CONTRACT_ADDRESS_LAB>",
    "soulValidationAttestationContractAddressLab": "<YOUR_SOUL_VALIDATION_ATTESTATION_CONTRACT_ADDRESS_LAB>",
    "soulRpcUrlSsmParamLab": "/lesser-host/api/infura/sepolia",

    "soulEnabledLive": "false",
    "soulChainIdLive": "8453",
    "soulRegistryContractAddressLive": "",
    "soulRpcUrlSsmParamLive": "",

    "soulMintSignerKeySsmParamLab": "/lesser-host/soul/lab/mint-signer-key",
    "soulMintSignerKeySsmParamLive": "/lesser-host/soul/live/mint-signer-key",

    "soulAdminSafeAddress": "<YOUR_SOUL_ADMIN_SAFE_ADDRESS>",
    "soulTxMode": "safe",
    "soulSupportedCapabilities": "social,commerce",

    "tipAdminSafeAddress": "<YOUR_TIP_ADMIN_SAFE_ADDRESS>",
    "tipDefaultHostWalletAddress": "<YOUR_TIP_DEFAULT_HOST_WALLET_ADDRESS>",
    "tipDefaultHostFeeBps": "500",
    "tipTxMode": "safe",

    "webauthnRpId": "lesser.host",
    "webauthnOrigins": "https://lab.lesser.host,https://lesser.host",

    "managedProvisioningEnabled": "true",
    "managedOrgVendingRoleArn": "arn:aws:iam::<YOUR_ORG_ACCOUNT_ID>:role/lesser-host-org-vending",
    "managedOrgVendingRoleName": "lesser-host-org-vending",
    "orgBootstrapControlPlaneAccountId": "<YOUR_CONTROL_PLANE_ACCOUNT_ID>",
    "orgBootstrapStackName": "lesser-host-org-bootstrap",
    "managedParentDomain": "greater.website",
    "managedParentHostedZoneId": "<YOUR_MANAGED_PARENT_HOSTED_ZONE_ID>",
    "managedAccountEmailTemplateLab": "<YOUR_EMAIL>+lab-{slug}@<YOUR_DOMAIN>",
    "managedAccountEmailTemplateLive": "<YOUR_EMAIL>+{slug}@<YOUR_DOMAIN>",
    "managedDefaultRegion": "us-east-1",
    "managedLesserDefaultVersion": "latest",
    "managedLesserBodyDefaultVersion": "latest"
  }
}
