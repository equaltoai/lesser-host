{
  "name": "lesser-host-contracts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "hardhat compile",
    "deploy:sepolia": "hardhat run --network sepolia scripts/deploy-tip-splitter.js",
    "lint": "solhint \"contracts/**/*.sol\"",
    "test": "hardhat compile && node --test test/*.test.js",
    "verify:sepolia": "hardhat verify --build-profile default --network sepolia"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "4.0.1",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.3",
    "@nomicfoundation/hardhat-verify": "^3.0.9",
    "@openzeppelin/contracts": "5.4.0",
    "dotenv": "16.6.1",
    "ethers": "6.15.0",
    "hardhat": "3.1.7",
    "solhint": "5.0.3"
  }
}
