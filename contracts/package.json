{
  "name": "lesser-host-contracts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "hardhat compile",
    "deploy:sepolia": "hardhat run --network sepolia scripts/deploy-tip-splitter.js",
