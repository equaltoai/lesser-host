    "test": "hardhat compile && node --test test/*.test.js"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.4",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.3",
    "@openzeppelin/contracts": "5.4.0",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "hardhat": "^3.1.9",
    "solhint": "^6.0.3"
  },
  "overrides": {
    "minimatch": "10.2.2"
  }
}
