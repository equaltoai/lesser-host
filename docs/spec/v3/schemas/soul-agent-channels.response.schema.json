{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lesser.host/spec/v3/schemas/soul-agent-channels.response.schema.json",
  "title": "GET /api/v1/soul/agents/{agentId}/channels response",
  "type": "object",
  "additionalProperties": false,
  "required": ["agentId", "channels", "contactPreferences", "updatedAt"],
  "properties": {
    "agentId": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "channels": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ens", "email", "phone"],
      "properties": {
        "ens": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["name"],
          "properties": {
            "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]*\\.eth$" },
            "resolverAddress": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
            "chain": { "type": "string", "default": "mainnet" }
          }
        },
        "email": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["address", "capabilities", "verified"],
          "properties": {
            "address": { "type": "string", "format": "email" },
            "capabilities": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "enum": ["receive", "send"] }
            },
            "protocols": {
              "type": "array",
              "items": { "type": "string", "enum": ["smtp", "imap"] }
            },
            "verified": { "type": "boolean" },
            "verifiedAt": { "type": "string", "format": "date-time" },
            "status": { "type": "string", "enum": ["active", "paused", "decommissioned"] }
          }
        },
        "phone": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["number", "capabilities", "verified"],
          "properties": {
            "number": { "type": "string", "pattern": "^\\+[1-9]\\d{1,14}$" },
            "capabilities": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": ["sms-receive", "sms-send", "voice-receive", "voice-send"]
              }
            },
            "provider": { "type": "string" },
            "verified": { "type": "boolean" },
            "verifiedAt": { "type": "string", "format": "date-time" },
            "status": { "type": "string", "enum": ["active", "paused", "decommissioned"] }
          }
        }
      }
    },
    "contactPreferences": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["preferred", "availability", "responseExpectation", "languages"],
      "properties": {
        "preferred": {
          "type": "string",
          "enum": ["email", "sms", "voice", "activitypub", "mcp"]
        },
        "fallback": {
          "type": "string",
          "enum": ["email", "sms", "voice", "activitypub", "mcp"]
        },
        "availability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["schedule"],
          "properties": {
            "schedule": {
              "type": "string",
              "enum": ["always", "business-hours", "custom"]
            },
            "timezone": { "type": "string" },
            "windows": {
              "type": ["array", "null"],
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["days", "startTime", "endTime"],
                "properties": {
                  "days": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "enum": ["mon", "tue", "wed", "thu", "fri", "sat", "sun"]
                    }
                  },
                  "startTime": {
                    "type": "string",
                    "pattern": "^[0-2][0-9]:[0-5][0-9]$"
                  },
                  "endTime": {
                    "type": "string",
                    "pattern": "^[0-2][0-9]:[0-5][0-9]$"
                  }
                }
              }
            }
          }
        },
        "responseExpectation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target", "guarantee"],
          "properties": {
            "target": { "type": "string" },
            "guarantee": {
              "type": "string",
              "enum": ["guaranteed", "best-effort"]
            }
          }
        },
        "rateLimits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "email": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "maxInboundPerHour": { "type": "integer", "minimum": 1 },
                "maxInboundPerDay": { "type": "integer", "minimum": 1 }
              }
            },
            "sms": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "maxInboundPerHour": { "type": "integer", "minimum": 1 },
                "maxInboundPerDay": { "type": "integer", "minimum": 1 }
              }
            },
            "voice": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "maxConcurrentCalls": { "type": "integer", "minimum": 1 },
                "maxCallsPerDay": { "type": "integer", "minimum": 1 }
              }
            }
          }
        },
        "languages": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^[a-z]{2}$" }
        },
        "contentTypes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "firstContact": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "requireSoul": { "type": "boolean", "default": false },
            "requireReputation": {
              "type": ["number", "null"],
              "minimum": 0,
              "maximum": 1
            },
            "introductionExpected": { "type": "boolean", "default": false }
          }
        }
      }
    },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}

